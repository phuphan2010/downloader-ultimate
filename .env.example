# ============================================================
# DOWNLOADER ULTIMATE — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# ------------------------------------
# APPLICATION
# ------------------------------------
APP_ENV=development          # development | production
DEBUG=false
SECRET_KEY=change-me-to-a-random-64-char-string

# CORS — comma-separated allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ------------------------------------
# REDIS / CELERY
# ------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ------------------------------------
# STORAGE
# ------------------------------------
STORAGE_BACKEND=local         # local | s3
STORAGE_LOCAL_PATH=/data/jobs
FILE_TTL_HOURS=24             # Auto delete files after N hours
MAX_DISK_USAGE_PERCENT=80.0   # Reject new jobs if disk > this %

# AWS S3 (only needed if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=downloader-ultimate
AWS_REGION=ap-southeast-1

# ------------------------------------
# VIDEO DOWNLOAD
# ------------------------------------
MAX_VIDEO_SIZE_MB=100
DOWNLOAD_TIMEOUT_SEC=300
DOWNLOAD_RETRY_COUNT=3

# ------------------------------------
# STT — WHISPER
# ------------------------------------
WHISPER_MODEL_SIZE=base       # tiny | base | small | medium | large
WHISPER_DEVICE=cpu            # cpu | cuda

# ------------------------------------
# TRANSLATION
# ------------------------------------
TRANSLATE_PROVIDER=google     # google | deepl
GOOGLE_TRANSLATE_API_KEY=     # Leave empty to use free googletrans
DEEPL_API_KEY=                # Get from deepl.com/pro-api

# ------------------------------------
# TTS (Text-to-Speech)
# ------------------------------------
TTS_PROVIDER=gtts             # gtts | elevenlabs
ELEVENLABS_API_KEY=           # Get from elevenlabs.io

# ------------------------------------
# SECURITY / AUTH
# ------------------------------------
API_KEY_HEADER=X-API-Key
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

# ------------------------------------
# MONITORING (optional)
# ------------------------------------
SENTRY_DSN=                   # Get from sentry.io
